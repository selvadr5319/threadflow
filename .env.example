# ─────────────────────────────────────────────
#  Slack — obtain from https://api.slack.com/apps
# ─────────────────────────────────────────────

# Bot User OAuth Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Signing Secret (from Basic Information > App Credentials)
SLACK_SIGNING_SECRET=your-signing-secret-here

# App-Level Token for Socket Mode (starts with xapp-)
# Requires connections:write scope
SLACK_APP_TOKEN=xapp-your-app-token-here

# ─────────────────────────────────────────────
#  SQLite
# ─────────────────────────────────────────────

# Path to SQLite database file (defaults to ./data.sqlite)
# SQLITE_PATH=./data.sqlite

# ─────────────────────────────────────────────
#  App
# ─────────────────────────────────────────────

PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# Public URL of the deployed app (used for board link in Slack App Home)
# Leave unset for local dev (defaults to http://localhost:PORT)
# APP_URL=https://your-app.railway.app
