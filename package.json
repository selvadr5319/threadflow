{
  "name": "slack-kanban",
  "version": "1.0.0",
  "description": "A lightweight Kanban board inside Slack — powered by Bolt SDK and PostgreSQL",
  "main": "dist/app.js",
  "scripts": {
    "build":       "tsc",
    "start":       "node dist/app.js",
    "dev":         "ts-node --transpile-only src/app.ts",
    "dev:watch":   "nodemon --watch src --ext ts --exec 'ts-node --transpile-only src/app.ts'",
    "typecheck":   "tsc --noEmit",
    "lint":        "eslint src --ext .ts",
    "lint:fix":    "eslint src --ext .ts --fix",
    "db:migrate":  "ts-node --transpile-only -e \"require('./src/db/migrate').runMigrations().then(() => process.exit(0))\"",
    "clean":       "rm -rf dist"
  },
  "dependencies": {
    "@slack/bolt":    "^3.21.1",
    "dotenv":         "^16.4.5",
    "express":        "^4.19.2",
    "pg":             "^8.12.0",
    "uuid":           "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node":    "^22.0.0",
    "@types/pg":      "^8.11.6",
    "@types/uuid":    "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser":        "^7.18.0",
    "eslint":    "^8.57.0",
    "nodemon":   "^3.1.4",
    "ts-node":   "^10.9.2",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
